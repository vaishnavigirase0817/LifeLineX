rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 1. User Profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
               data.email is string && data.email.size() > 0 && data.email.size() <= 100 &&
               data.email == request.auth.token.email;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'healthScore', 'avatar', 'updatedAt']);
    }

    // 2. Emergency Alerts
    match /alerts/{alertId} {
      function isValidAlert(data) {
        return data.userId == request.auth.uid &&
               data.status in ['active', 'resolved', 'false-alarm'] &&
               data.timestamp == request.time;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(alertId) && isValidAlert(incoming());
      allow update: if isSignedIn() && isOwner(existing().userId) && 
                    incoming().status in ['active', 'resolved', 'false-alarm'] &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['status', 'resolvedAt']);
    }
  }
}
